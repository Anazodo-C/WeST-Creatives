# ── Database (optional — Railway Postgres for persistence) ──────────────────
# Leave unset for local dev: a zero-config SQLite file at .data/vibe.db.
# Set this to a Postgres connection string (e.g. from a Railway Postgres
# plugin — Railway dashboard → your Postgres service → Variables →
# DATABASE_URL) to persist agents/wallets/content history permanently,
# which matters once this is deployed to Vercel (its filesystem is wiped on
# every deploy, so SQLite there only lasts until the next push).
DATABASE_URL=

# ── Circle (wallets, payments, Arc contract execution) ──────────────────────
# Get these from https://console.circle.com — Keys > Create a key (Standard Key)
# and Wallets > Entity Secret registration.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
# Optional: reuse one wallet set instead of creating a new one per wallet.
CIRCLE_WALLET_SET_ID=

# Platform treasury wallet that receives the 10% platform fee.
PLATFORM_WALLET_ADDRESS=

# ── Arc Testnet ──────────────────────────────────────────────────────────────
# Leave unset to use viem's built-in arcTestnet chain defaults.
ARC_TESTNET_RPC_URL=
# USDC token id on Arc Testnet, used for Circle transaction calls.
ARC_USDC_TOKEN_ID=

# ── Model providers ──────────────────────────────────────────────────────────
# Text generation, prompt enhancement, LLM-as-judge evaluation.
ANTHROPIC_API_KEY=

# Image generation, via OpenRouter. Get a key at openrouter.ai/keys and add
# prepaid credits at openrouter.ai/credits — $5-10 is plenty to start (see
# per-image cost table below). Chosen specifically because OpenRouter holds
# the billing relationship with the underlying provider directly — no Google
# Cloud project/billing-account setup needed on this app's side (unlike
# calling Gemini's own API directly, whose image model has a hard 0
# free-tier requests/day).
OPENROUTER_API_KEY=
# Default model, overridable here or via OPENROUTER_IMAGE_MODEL (see
# openrouter.ai/collections/image-models for the full current list/pricing):
#   black-forest-labs/flux.2-klein-4b  ~$0.014-0.03/image (cheapest; default)
#   bytedance-seed/seedream-4.5        $0.04/image flat (predictable, strong quality)
#   google/gemini-2.5-flash-image      ~$0.02-0.04/image (per-token — see note below)
#   google/gemini-3.1-flash-lite-image ~$0.03-0.05/image (per-token — see note below)
# Per-token (Gemini/GPT-image) models run an affordability preflight against
# max_tokens (capped at 4096 in image.ts) rather than a flat per-image price
# — flux.2-klein-4b and seedream-4.5 are billed per output pixel instead, so
# there's no such preflight to trip even on a small balance.
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b
# Tried once more, on a different model+provider, if the primary model
# errors or gives a poor-fidelity result.
OPENROUTER_FALLBACK_IMAGE_MODEL=bytedance-seed/seedream-4.5

# Video generation, also via OpenRouter (POST /api/v1/videos, launched April
# 2026 — see openrouter.ai/docs/guides/overview/multimodal/video-generation).
# Uses the same OPENROUTER_API_KEY as image generation above — no separate
# signup. Real jobs take minutes to render, so src/lib/agents/video.ts submits
# the job and returns a storyboard placeholder immediately; the dashboard
# polls src/app/api/content/video-status until the job completes, then swaps
# in the real video URL.
# Default model, overridable here or via OPENROUTER_VIDEO_MODEL (see
# openrouter.ai/collections/video-models for the full current list/pricing):
#   bytedance/seedance-2.0-fast  ~$0.02/s (cheapest/fastest; default)
#   alibaba/wan-2.6              ~$0.02-0.03/s
#   kwaivgi/kling-v3.0-std       ~$0.03/s
OPENROUTER_VIDEO_MODEL=bytedance/seedance-2.0-fast
# Clip length in seconds — kept short by default to match nanopayment-scale
# pricing (src/lib/pricing.ts).
OPENROUTER_VIDEO_DURATION_SECONDS=4

# Audio (dialogue / sound effects).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Auth (optional, for real Google sign-in on /signup) ─────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Wallet connect (optional, for RainbowKit's WalletConnect/mobile QR) ─────
# Free project id from https://cloud.reown.com (formerly WalletConnect
# Cloud) — injected browser wallets (MetaMask, Rabby, etc.) work fine
# without this. Without a real id, you may see "Origin ... not found on
# Allowlist" in the console — harmless for injected wallets, but to clear
# it: create a project at cloud.reown.com, add http://localhost:3000 and
# your deployed domain under that project's Allowed Origins, then paste
# the project id below.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Your deployed domain (e.g. https://west-creatives.vercel.app). Used as
# RainbowKit's app metadata URL. Not just cosmetic — leaving this fully
# unset is fine (there's a hardcoded fallback in src/lib/web3.ts), but if
# you do set it, use a real absolute URL, not localhost, since this value
# is baked in at build time.
NEXT_PUBLIC_APP_URL=

# ── Contact form ─────────────────────────────────────────────────────────────
# Free API key from https://resend.com. Without it, contact submissions are
# saved to the local database instead of emailed.
RESEND_API_KEY=
CONTACT_EMAIL=chukwumanazodo@gmail.com
CONTACT_FROM_EMAIL=West Creatives <onboarding@resend.dev>
